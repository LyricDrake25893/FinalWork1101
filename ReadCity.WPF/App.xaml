<Application x:Class="ReadCity.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ReadCity.WPF.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Colour palette -->
        <Color x:Key="PrimaryColor">#FFFFFFFF</Color>
        <Color x:Key="SecondaryColor">#FFDAA520</Color>
        <Color x:Key="AccentColor">#FFB8860B</Color>

        <SolidColorBrush x:Key="PrimaryBrush"   Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="TextBrush"      Color="#FF1A1A1A"/>

        <!-- Typography -->
        <FontFamily x:Key="AppFont">Calibri</FontFamily>

        <!-- Base button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily"        Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"          Value="14"/>
            <Setter Property="Background"        Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="Padding"           Value="14,7"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF8B6914"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent (smaller) button -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="10,5"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="AppTextBox" TargetType="TextBox">
            <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="BorderBrush"     Value="#FFB8860B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="AppComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="6,4"/>
        </Style>

        <!-- Header bar style -->
        <Style x:Key="HeaderBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Padding"    Value="16,10"/>
        </Style>

    </Application.Resources>
</Application>
